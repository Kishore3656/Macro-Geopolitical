{
  "buildCommand": "pip install -r requirements.txt && python prediction/train.py 2>/dev/null || true",
  "outputDirectory": ".",
  "env": {
    "GTI_DB": "gti.db",
    "NEWS_DB": "news.db",
    "MARKET_DB": "market.db",
    "PREDICTIONS_DB": "predictions.db",
    "PYTHONUNBUFFERED": "1"
  },
  "functions": {
    "api/main.py": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/main.py"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
